{
  "name": "create-blit386-workspace",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for the BLIT386 scaffolder (create-blit386) and kit (@blit386/kit).",
  "author": {
    "name": "Václav Vančura",
    "url": "https://github.com/vancura"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blit386/create-blit386.git"
  },
  "homepage": "https://blit386.dev",
  "bugs": {
    "url": "https://github.com/blit386/blit386/issues"
  },
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=22.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "undici": ">=8.5.0 <9",
      "fast-uri": ">=4.1.1"
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write . && prettier --write \"**/*.{md,mdx,mdc,yml,yaml}\"",
    "format:check": "biome format . && prettier --check \"**/*.{md,mdx,mdc,yml,yaml}\"",
    "spellcheck": "cspell \"packages/*/src/**/*.ts\" \"packages/*/README.md\" \"packages/kit/content/**/*.md\" \".claude/skills/**/*.md\" \".claude/rules/**/*.md\" \"README.md\" \"CLAUDE.md\" \"CONTRIBUTING.md\" \"CODE_OF_CONDUCT.md\" \"CREATE_BLIT386_DESIGN.md\" \"PUBLISHING.md\" --no-progress",
    "docs:links": "node scripts/check-markdown-links.mjs",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "security:audit": "pnpm audit --audit-level=moderate",
    "security:audit:prod": "pnpm audit --prod --audit-level=moderate",
    "security:audit:fix": "pnpm audit --fix",
    "preflight": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run spellcheck && pnpm run knip && pnpm run docs:links && pnpm run build && pnpm run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,json,jsonc}": [
      "biome check --write"
    ],
    "*.{md,mdx,mdc,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,js,md,mdx,mdc}": [
      "cspell --no-progress --no-must-find-files"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "cspell": "^10.0.1",
    "husky": "^9.1.7",
    "knip": "^6.26.0",
    "lint-staged": "^16.4.0",
    "markdown-link-check": "^3.14.2",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3"
  }
}
