{
  "name": "create-blit-tech-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for the Blit-Tech scaffolder (create-blit-tech) and kit (@blit-tech/kit).",
  "author": "Václav Vančura",
  "license": "ISC",
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=22.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write . && prettier --write \"**/*.{md,mdx,yml,yaml}\"",
    "format:check": "biome check . && prettier --check \"**/*.{md,mdx,yml,yaml}\"",
    "spellcheck": "cspell \"packages/*/src/**/*.ts\" \"packages/kit/content/**/*.md\" \"README.md\" \"CLAUDE.md\" --no-progress",
    "docs:links": "node scripts/check-markdown-links.mjs",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "security:audit": "pnpm audit --audit-level=moderate",
    "security:audit:prod": "pnpm audit --prod --audit-level=moderate",
    "security:audit:fix": "pnpm audit --fix",
    "preflight": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run spellcheck && pnpm run knip && pnpm run docs:links && pnpm run build && pnpm run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,json,jsonc}": [
      "biome check --write"
    ],
    "*.{md,mdx,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,js,md,mdx}": [
      "cspell --no-progress --no-must-find-files"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "cspell": "^10.0.0",
    "husky": "^9.1.7",
    "knip": "^6.14.2",
    "lint-staged": "^16.4.0",
    "markdown-link-check": "^3.14.2",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
