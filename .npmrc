shared-workspace-lockfile=false

# Supply-chain hardening for pnpm 10.
minimum-release-age=10080
minimum-release-age-exclude[]=ws
minimum-release-age-exclude[]=brace-expansion
minimum-release-age-exclude[]=uuid
minimum-release-age-exclude[]=@types/node
minimum-release-age-exclude[]=@commitlint/cli
minimum-release-age-exclude[]=@commitlint/config-conventional
minimum-release-age-exclude[]=cspell
minimum-release-age-exclude[]=knip
minimum-release-age-exclude[]=lint-staged
minimum-release-age-exclude[]=markdown-link-check
minimum-release-age-exclude[]=husky
minimum-release-age-exclude[]=undici
block-exotic-subdeps=true
strict-dep-builds=true
